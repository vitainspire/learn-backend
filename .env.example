# Copy this file to .env and fill in your values.
# The .env file is loaded automatically by python-dotenv.

# ---- OpenRouter (all AI calls) ----
# Get key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-key-here

# ---- OpenRouter model tiers (tested and validated) ----
# fast:     plain text tasks — study plans, TOC parsing, answer feedback ($0.05/1M)
OPENROUTER_MODEL_FAST=openai/gpt-5-nano
# quality:  complex JSON — lesson plans, worksheets, quizzes, grading ($0.12/1M)
OPENROUTER_MODEL_QUALITY=google/gemma-4-31b-it
# reasoning: reserved for future reasoning-heavy tasks ($0.25/1M)
OPENROUTER_MODEL_REASONING=openai/gpt-5-mini
# vision:   textbook image/page analysis — supports multimodal ($0.12/1M)
OPENROUTER_MODEL_VISION=google/gemma-4-31b-it

# ---- PostgreSQL ----
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://postgres:your-password-here@localhost:5432/edulearn

# ---- Supabase ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here
# Service role key bypasses RLS for server-side writes — get it from Supabase dashboard > Settings > API
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ---- Dev helpers ----
# Set to "1" to insert a demo teacher + student when running init_db.py
SEED_DEV_DATA=1


# ---- Hugging Face (for image generation) ----
HF_TOKEN=your-huggingface-token-here

# ---- Replicate (for image generation fallback) ----
# Free tier: 50 predictions/month
# Get token from: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=your-replicate-token-here

# ---- Stability AI (for image generation fallback) ----
# Free tier: 25 credits/month
# Get API key from: https://platform.stability.ai/account/keys
STABILITY_API_KEY=your-stability-api-key-here

# ---- Redis Cloud (Celery broker + result backend) ----
# Create a free database at: https://app.redislabs.com/
# Copy the "Public endpoint" from the database page, then build the URL:
#   rediss://default:<password>@<host>:<port>
# The double-s (rediss://) enables TLS — required for Redis Cloud.
REDIS_URL=rediss://default:your-redis-password@your-host.redis-cloud.com:PORT
