# Copy this file to .env and fill in your values.
# The .env file is loaded automatically by python-dotenv.

# ---- Gemini AI ----
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# ---- PostgreSQL ----
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://postgres:your-password-here@localhost:5432/edulearn

# ---- Supabase ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here
# Service role key bypasses RLS for server-side writes — get it from Supabase dashboard > Settings > API
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ---- Dev helpers ----
# Set to "1" to insert a demo teacher + student when running init_db.py
SEED_DEV_DATA=1


# ---- Hugging Face (for image generation) ----
HF_TOKEN=your-huggingface-token-here

# ---- Replicate (for image generation fallback) ----
# Free tier: 50 predictions/month
# Get token from: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=your-replicate-token-here

# ---- Stability AI (for image generation fallback) ----
# Free tier: 25 credits/month
# Get API key from: https://platform.stability.ai/account/keys
STABILITY_API_KEY=your-stability-api-key-here
